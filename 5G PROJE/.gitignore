# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Ortam ─────────────────────────────────────────────────────
.env
venv/
.venv/
env/
ENV/

