# Sinaptic5G — Ortam Değişkenleri Şablonu
# ==========================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env
#
# Sağlayıcı değerleri yalnız Turkcell onboarding çıktısından doldurulmalıdır.
# Yerel mock/simülatör çıktıları gerçek kabul testi veya KPI kanıtı değildir.

# ─── Turkcell Open Gateway (Gerçek API) ──────────────────────────────────────
TURKCELL_QOD_CLIENT_ID=backend_qod_client_id
TURKCELL_QOD_CLIENT_SECRET=backend_qod_client_secret
TURKCELL_QOD_PROFILE=provider_issued_profile
TURKCELL_TOKEN_URL=provider_onboarding_token_url
TURKCELL_NUMBER_VERIFY_URL=provider_onboarding_number_verification_url
TURKCELL_QOD_BASE_URL=provider_onboarding_qod_base_url
QOD_APPLICATION_SERVER_IPV4=203.0.113.10
QOD_APPLICATION_SERVER_PORT=443
QOD_DEVICE_PORT=0
QOD_TRANSPORT_PROTOCOL=TCP
QOD_NOTIFICATION_URL=https://example.invalid/api/qod/callback
QOD_DURATION_SECONDS=300
QOD_BENEFIT_MODEL_PATH=configs/qod_benefit_model.json

# ─── WebRTC signaling / GPU media service ───────────────────────────────────
MEDIA_SERVICE_TOKEN=replace-with-at-least-32-random-characters
MEDIA_BASE_URL=https://media.your-domain.example
WEBRTC_SIGNALING_TTL_SECONDS=60
WEBRTC_ICE_SERVERS_JSON=[]

# ─── Veritabanı ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tripwire:tripwire123@localhost:5432/tripwire_db
REDIS_URL=redis://localhost:6379/0

# ─── YZ Modelleri ─────────────────────────────────────────────────────────────
YOLO_LIGHT_MODEL_PATH=models/yolov8n_tripwire.pt
YOLO_HEAVY_MODEL_PATH=models/yolov8l_tripwire.pt

# ─── Sunucu ───────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SECRET_KEY=sinaptic5g-change-this-in-production-use-long-random-string

# ─── Güvenlik ─────────────────────────────────────────────────────────────────
# Üretimde CORS origins'i kısıtlayın:
ALLOWED_ORIGIN=https://your-domain.example

# ─── Loglama ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
